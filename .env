# .env file 
# -----------------------------------------------------------------------------
# NOTE ON IP ADDRESSES: 
# If you are running Music Assistant and this Hybrid App on the same NAS/Server, 
# MASS_IP, APP_IP, and HOST_IP will all be the EXACT SAME local IP address.
# -----------------------------------------------------------------------------

# MASS (MUSIC ASSISTANT) SERVER SETTINGS
MASS_IP=xxx.xxx.x.xx
# MASS_PORT defaults to 8095. Change only if you customized it in Music Assistant.
MASS_PORT=8095
MASS_USERNAME=xxxxx
MASS_PASSWORD=xxxxxxxx

# BOSE SOUNDTOUCH HYBRID 2026 SERVER SETTINGS
# The speaker's internal Bose Cloud Emulation URLs (marge, bmxRegistry, etc) 
# will be rewritten to match these values when using the Cloud Emulation Feature.
# APP_IP must be the actual local IP address of the server/NAS running this container.
APP_IP=xxx.xxx.x.xx
# APP_PORT defaults to 3000 (Standard for Node.js). Change only if you have a port conflict.
APP_PORT=3000

# HOST SERVER SSH SETTINGS 
# Credentials for the machine running this app (used by the tools.html UI to restart the container).
HOST_IP=xxx.xxx.x.xx
# HOST_SSH_PORT defaults to 22 (Standard SSH port).
HOST_SSH_PORT=22
HOST_SSH_USER=xxxxx
HOST_SSH_PASS=xxxxxxxx

# LOGGING
LOG_DIR=./logs

# WIRELESS LINK ADAPTER WORKAROUND
# Set to 'true' to intercept WLA UI preset clicks and route directly to Music Assistant.
# Set to 'false' to let the WLA hardware handle presets normally (if Bose leaves an active dummy endpoint in their servers after May 2026 to keep devices stable).
WLA_PRESET_BYPASS=true